<div class="col">
  <div class="card project-card h-100 hoverable">
    <div class="card-body">
      {% if project.label %}
        <p class="project-label">{{ project.label }}</p>
      {% endif %}
      <h2 class="card-title">
        <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">{{ project.title }}</a>
      </h2>
      <p class="card-text">{{ project.description }}</p>
      {% if project.outcome %}
        <p class="project-outcome">{{ project.outcome }}</p>
      {% endif %}
      {% if project.tech %}
        <div class="project-tags" aria-label="Technology stack">
          {% for technology in project.tech %}
            <span class="project-tag">{{ technology }}</span>
          {% endfor %}
        </div>
      {% endif %}
      <div class="project-card-actions">
        <a class="project-read-more" href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">View project</a>
        {% if project.github %}
          <a class="project-source" href="{{ project.github }}" aria-label="Source code for {{ project.title }}"><i class="fa-brands fa-github"></i></a>
        {% endif %}
      </div>
    </div>
  </div>
</div>
